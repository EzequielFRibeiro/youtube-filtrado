PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=youtube_filtrado
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=youtube-filtrado-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=524288000

# Geolocation API (ipinfo.io free tier)
GEOLOCATION_API_TOKEN=your_ipinfo_token

# CORS
FRONTEND_URL=http://localhost:3000
